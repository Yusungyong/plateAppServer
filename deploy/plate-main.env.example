DB_URL=jdbc:postgresql://your-db-host:5432/your-db-name
DB_USERNAME=your-db-username
DB_PASSWORD=your-db-password

# 32 bytes or more
JWT_SECRET=replace-with-32-bytes-or-more-secret
# Comma-separated frontend origins. Do not use '*' with credentials.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://verify.example.com,https://www.example.com
CORS_ALLOW_CREDENTIALS=false
CORS_MAX_AGE=1h
# Optional deployment-time preflight smoke origin.
CORS_SMOKE_ORIGIN=http://localhost:3001
FEEDBACK_CONTACT_RETENTION_DAYS=90
FEEDBACK_CONTACT_PURGE_CRON="0 30 3 * * *"

APPLE_CLIENT_ID=your-apple-client-id
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_ANDROID_CLIENT_ID=398195276422-4hosgi2odjcq47hoqhrk5lc37eo5dcbi.apps.googleusercontent.com
# Optional comma-separated override/additional Google OAuth client ids.
GOOGLE_ALLOWED_CLIENT_IDS=

# Optional
SERVER_PORT=8090
HEALTH_MAX_RETRIES=90
HEALTH_SLEEP_SECONDS=2
HEALTH_CURL_TIMEOUT_SECONDS=5
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# CloudFront distribution URL, for example https://d111111abcdef8.cloudfront.net
AWS_S3_CDN_BASE_URL=
OPENAI_API_KEY=
MAIL_PASSWORD=
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
NAVER_LOCAL_SEARCH_CLIENT_ID=
NAVER_LOCAL_SEARCH_CLIENT_SECRET=
GOOGLE_PLACES_API_KEY=
KAKAO_DEV_RESTAPI_KEY=
KAKAO_CLIENT_SECRET=
FIREBASE_ENABLED=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_PATH=
